<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BlackBoxBuddy.ViewModels"
             xmlns:models="using:BlackBoxBuddy.Models"
             xmlns:conv="using:BlackBoxBuddy.Converters"
             x:Class="BlackBoxBuddy.Views.RecordingsPage"
             x:DataType="vm:RecordingsViewModel">

  <ContentPage.Resources>
    <conv:EventTypeToBrushConverter x:Key="EventTypeToBrush"/>
    <conv:BytesToBitmapConverter x:Key="BytesToBitmap"/>
    <conv:FileSizeConverter x:Key="FileSizeConverter"/>
    <conv:EventTypeToStringConverter x:Key="EventTypeToString"/>
    <conv:EventTypeToVisibilityConverter x:Key="EventTypeToVisibility"/>
    <conv:ArchivedMultiConverter x:Key="ArchivedMultiConverter"/>
    <conv:RecordingIsSelectedConverter x:Key="RecordingIsSelectedConverter"/>
    <conv:NullFilterActiveBrushConverter x:Key="FilterActiveBrush"/>
  </ContentPage.Resources>

  <!-- Root Panel for overlay support -->
  <Panel>

    <Grid RowDefinitions="Auto,Auto,*">

      <!-- Row 0: Filter chip bar + Select/Done button bar -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,16,16,0">

        <!-- Filter chips -->
        <ScrollViewer Grid.Column="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <StackPanel Orientation="Horizontal" Spacing="8">

            <!-- All filter chip -->
            <Button Content="All"
                    CornerRadius="16"
                    Padding="12,8"
                    FontSize="14"
                    FontWeight="Normal"
                    Foreground="White"
                    Background="{Binding SelectedFilter, Converter={StaticResource FilterActiveBrush}}"
                    Command="{Binding SetFilterCommand}"
                    CommandParameter="{x:Null}"/>

            <!-- Radar filter chip -->
            <Button Content="Radar"
                    CornerRadius="16"
                    Padding="12,8"
                    FontSize="14"
                    FontWeight="Normal"
                    Foreground="White"
                    Command="{Binding SetFilterCommand}">
              <Button.Background>
                <Binding Path="SelectedFilter" Converter="{StaticResource FilterActiveBrush}">
                  <Binding.ConverterParameter>
                    <models:EventType>Radar</models:EventType>
                  </Binding.ConverterParameter>
                </Binding>
              </Button.Background>
              <Button.CommandParameter>
                <models:EventType>Radar</models:EventType>
              </Button.CommandParameter>
            </Button>

            <!-- G-Shock filter chip -->
            <Button Content="G-Shock"
                    CornerRadius="16"
                    Padding="12,8"
                    FontSize="14"
                    FontWeight="Normal"
                    Foreground="White"
                    Command="{Binding SetFilterCommand}">
              <Button.Background>
                <Binding Path="SelectedFilter" Converter="{StaticResource FilterActiveBrush}">
                  <Binding.ConverterParameter>
                    <models:EventType>GShock</models:EventType>
                  </Binding.ConverterParameter>
                </Binding>
              </Button.Background>
              <Button.CommandParameter>
                <models:EventType>GShock</models:EventType>
              </Button.CommandParameter>
            </Button>

            <!-- Parking filter chip -->
            <Button Content="Parking"
                    CornerRadius="16"
                    Padding="12,8"
                    FontSize="14"
                    FontWeight="Normal"
                    Foreground="White"
                    Command="{Binding SetFilterCommand}">
              <Button.Background>
                <Binding Path="SelectedFilter" Converter="{StaticResource FilterActiveBrush}">
                  <Binding.ConverterParameter>
                    <models:EventType>Parking</models:EventType>
                  </Binding.ConverterParameter>
                </Binding>
              </Button.Background>
              <Button.CommandParameter>
                <models:EventType>Parking</models:EventType>
              </Button.CommandParameter>
            </Button>

          </StackPanel>
        </ScrollViewer>

        <!-- Select/Done button bar (right side) -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
          <!-- Not in multi-select mode -->
          <Button Content="Select Clips"
                  Command="{Binding ToggleMultiSelectCommand}"
                  IsVisible="{Binding !IsMultiSelectMode}"
                  FontSize="14" Padding="12,8"/>
          <!-- In multi-select mode -->
          <Button Content="Select All"
                  Command="{Binding SelectAllCommand}"
                  IsVisible="{Binding IsMultiSelectMode}"
                  FontSize="14" Padding="12,8"/>
          <Button Content="Done Selecting"
                  Command="{Binding ToggleMultiSelectCommand}"
                  IsVisible="{Binding IsMultiSelectMode}"
                  FontSize="14" Padding="12,8"/>
        </StackPanel>

      </Grid>

      <!-- Row 1: Archive Selected bottom floating bar (shown in multi-select) -->
      <!-- Placed in Row 1 as a fixed bar above the list -->
      <Border Grid.Row="1"
              IsVisible="{Binding IsMultiSelectMode}"
              Background="#CC000000"
              HorizontalAlignment="Stretch"
              Padding="16,8">
        <Button HorizontalAlignment="Stretch"
                Background="#2196F3"
                Command="{Binding ArchiveSelectedCommand}">
          <TextBlock FontSize="14" Foreground="White">
            <TextBlock.Text>
              <MultiBinding StringFormat="Archive Selected ({0})">
                <Binding Path="SelectedCount"/>
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </Button>
      </Border>

      <!-- Row 2: Content area -->
      <Panel Grid.Row="2">

        <!-- Loading state -->
        <StackPanel IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <ProgressBar IsIndeterminate="True" Width="160" Height="4"/>
          <TextBlock Text="Loading recordings..."
                     FontSize="14"
                     HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Empty state — no device connected -->
        <StackPanel IsVisible="{Binding IsEmpty}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

          <!-- No device connected -->
          <StackPanel IsVisible="{Binding !IsDeviceConnected}"
                      Spacing="8"
                      HorizontalAlignment="Center">
            <TextBlock Text="Your dashcam recordings will appear here"
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock Text="Connect your dashcam to browse recordings."
                       FontSize="14"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
          </StackPanel>

          <!-- Filter active but no matches -->
          <StackPanel IsVisible="{Binding HasActiveFilter}"
                      Spacing="8"
                      HorizontalAlignment="Center">
            <TextBlock Text="No matches for this filter"
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock Text="No recordings match this filter. Try selecting All."
                       FontSize="14"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
          </StackPanel>

        </StackPanel>

        <!-- Recording list — hidden while loading -->
        <ListBox x:Name="RecordingList"
                 ItemsSource="{Binding DisplayItems}"
                 SelectionMode="Single"
                 Margin="16"
                 IsVisible="{Binding !IsLoading}">

          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Margin" Value="0,0,0,8"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </ListBox.Styles>

          <ListBox.DataTemplates>

            <!-- DataTemplate for standalone Recording items -->
            <DataTemplate DataType="models:Recording">
              <Button Command="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).OpenRecordingCommand}"
                      CommandParameter="{Binding}"
                      Background="Transparent"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Border CornerRadius="8"
                        Padding="12"
                        Background="#1EFFFFFF">
                  <!-- Panel wraps the card to allow checkbox overlay -->
                  <Panel>
                    <Grid ColumnDefinitions="160,*" ColumnSpacing="12">

                      <!-- Thumbnail with event badge and archived badge overlay -->
                      <Panel Grid.Column="0">
                        <Image Source="{Binding ThumbnailData, Converter={StaticResource BytesToBitmap}}"
                               Width="160"
                               Height="90"
                               Stretch="UniformToFill"/>
                        <!-- Event badge — hidden for EventType.None -->
                        <Border CornerRadius="4"
                                Padding="4,2"
                                Background="{Binding EventType, Converter={StaticResource EventTypeToBrush}}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="4"
                                IsVisible="{Binding EventType, Converter={StaticResource EventTypeToVisibility}}">
                          <TextBlock Text="{Binding EventType, Converter={StaticResource EventTypeToString}}"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     Foreground="White"/>
                        </Border>
                        <!-- Archived badge (green, bottom-right of thumbnail) -->
                        <Border CornerRadius="4" Padding="4,2" Background="#4CAF50"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4">
                          <Border.IsVisible>
                            <MultiBinding Converter="{StaticResource ArchivedMultiConverter}">
                              <Binding Path="FileName"/>
                              <Binding Path="$parent[ListBox].((vm:RecordingsViewModel)DataContext).ArchivedFileNames"/>
                            </MultiBinding>
                          </Border.IsVisible>
                          <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBlock Text="Archived" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                          </StackPanel>
                        </Border>
                      </Panel>

                      <!-- Metadata column -->
                      <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DateTime, StringFormat='{}{0:MMM dd, yyyy  HH:mm}'}"
                                   FontSize="14"
                                   Opacity="0.85"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                     FontSize="14"
                                     Opacity="0.85"/>
                          <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                     FontSize="14"
                                     Opacity="0.85"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding AvgSpeed, StringFormat='{}{0:F0} km/h'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                          <TextBlock Text="{Binding PeakGForce, StringFormat='{}{0:F1}g'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                          <TextBlock Text="{Binding Distance, StringFormat='{}{0:F1} km'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                        </StackPanel>
                      </StackPanel>

                    </Grid>

                    <!-- Multi-select checkbox overlay (top-left of card) -->
                    <CheckBox IsVisible="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).IsMultiSelectMode}"
                              Command="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).ToggleRecordingSelectionCommand}"
                              CommandParameter="{Binding}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Margin="4">
                      <CheckBox.IsChecked>
                        <MultiBinding Converter="{StaticResource RecordingIsSelectedConverter}" Mode="OneWay">
                          <Binding Path="."/>
                          <Binding Path="$parent[ListBox].((vm:RecordingsViewModel)DataContext).SelectedRecordings"/>
                        </MultiBinding>
                      </CheckBox.IsChecked>
                    </CheckBox>

                  </Panel>
                </Border>
              </Button>
            </DataTemplate>

            <!-- DataTemplate for TripGroup items -->
            <DataTemplate DataType="models:TripGroup">
              <StackPanel Spacing="4">

                <!-- Trip header card -->
                <Button Command="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).OpenTripCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        Padding="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                  <Border CornerRadius="8"
                          Padding="12"
                          Background="#26FFFFFF">
                    <Grid ColumnDefinitions="Auto,*,Auto">

                      <!-- Trip label and clip count -->
                      <StackPanel Grid.Column="0"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center">
                        <TextBlock Text="Trip"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock FontSize="12"
                                   Opacity="0.7">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} clips">
                              <Binding Path="Clips.Count"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </StackPanel>

                      <!-- Aggregated stats -->
                      <StackPanel Grid.Column="1" Spacing="4" Margin="16,0">
                        <TextBlock Text="{Binding StartTime, StringFormat='{}{0:MMM dd, yyyy  HH:mm}'}"
                                   FontSize="14"
                                   Opacity="0.85"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding TotalDuration, StringFormat='{}{0:mm\\:ss}'}"
                                     FontSize="14"
                                     Opacity="0.85"/>
                          <TextBlock Text="{Binding TotalDistance, StringFormat='{}{0:F1} km'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                          <TextBlock Text="{Binding AvgSpeed, StringFormat='{}{0:F0} km/h'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                          <TextBlock Text="{Binding PeakGForce, StringFormat='{}{0:F1}g'}"
                                     FontSize="14"
                                     Opacity="0.7"/>
                        </StackPanel>
                      </StackPanel>

                    </Grid>
                  </Border>
                </Button>

                <!-- Nested clips indented 24px per UI-SPEC -->
                <ItemsControl ItemsSource="{Binding Clips}" Margin="24,0,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Recording">
                      <Button Command="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).OpenRecordingCommand}"
                              CommandParameter="{Binding}"
                              Background="Transparent"
                              Padding="0"
                              Margin="0,4"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <Border CornerRadius="8"
                                Padding="8"
                                Background="#1EFFFFFF">
                          <Panel>
                            <Grid ColumnDefinitions="120,*" ColumnSpacing="8">
                              <Panel Grid.Column="0">
                                <Image Source="{Binding ThumbnailData, Converter={StaticResource BytesToBitmap}, ConverterParameter=120x68}"
                                       Width="120"
                                       Height="68"
                                       Stretch="UniformToFill"/>
                                <!-- Archived badge -->
                                <Border CornerRadius="4" Padding="4,2" Background="#4CAF50"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4">
                                  <Border.IsVisible>
                                    <MultiBinding Converter="{StaticResource ArchivedMultiConverter}">
                                      <Binding Path="FileName"/>
                                      <Binding Path="$parent[ListBox].((vm:RecordingsViewModel)DataContext).ArchivedFileNames"/>
                                    </MultiBinding>
                                  </Border.IsVisible>
                                  <TextBlock Text="Archived" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                              </Panel>
                              <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DateTime, StringFormat='{}{0:HH:mm}'}"
                                           FontSize="14"
                                           Opacity="0.85"/>
                                <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                           FontSize="12"
                                           Opacity="0.7"/>
                              </StackPanel>
                            </Grid>

                            <!-- Multi-select checkbox overlay -->
                            <CheckBox IsVisible="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).IsMultiSelectMode}"
                                      Command="{Binding $parent[ListBox].((vm:RecordingsViewModel)DataContext).ToggleRecordingSelectionCommand}"
                                      CommandParameter="{Binding}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Margin="4">
                              <CheckBox.IsChecked>
                                <MultiBinding Converter="{StaticResource RecordingIsSelectedConverter}" Mode="OneWay">
                                  <Binding Path="."/>
                                  <Binding Path="$parent[ListBox].((vm:RecordingsViewModel)DataContext).SelectedRecordings"/>
                                </MultiBinding>
                              </CheckBox.IsChecked>
                            </CheckBox>
                          </Panel>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>

          </ListBox.DataTemplates>

        </ListBox>

      </Panel>

    </Grid>

    <!-- Detail page overlay (shown when a recording/trip is tapped) -->
    <Border IsVisible="{Binding IsDetailVisible}"
            Background="#FF1E1E1E"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <Grid RowDefinitions="Auto,*" DataContext="{Binding ActiveDetailViewModel}"
            x:DataType="vm:RecordingDetailViewModel">
        <!-- Back button -->
        <Button Grid.Row="0"
                Command="{Binding $parent[ContentPage].((vm:RecordingsViewModel)DataContext).CloseDetailCommand}"
                Margin="16,8" Padding="12,8"
                HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                       Width="16" Height="16"/>
            <TextBlock Text="Back" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <!-- Detail content inline -->
        <ScrollViewer Grid.Row="1">
          <StackPanel Spacing="0">

            <!-- Thumbnail / video area -->
            <Panel Background="#111111" Height="300">
              <!-- Thumbnail (shown when not playing) -->
              <Image IsVisible="{Binding !IsPlaying}"
                     Source="{Binding CurrentRecording.ThumbnailData, Converter={StaticResource BytesToBitmap}, ConverterParameter=160x90}"
                     Stretch="UniformToFill" Height="300" HorizontalAlignment="Stretch"/>
              <!-- VideoView host (populated in code-behind with Desktop VideoView) -->
              <ContentControl x:Name="DetailVideoHost"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
              <!-- Play button overlay (shown when not playing) -->
              <Button IsVisible="{Binding !IsPlaying}"
                      Command="{Binding PlayPauseCommand}"
                      Background="#88000000" Width="64" Height="64" CornerRadius="32"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="28" Height="28" Foreground="White"/>
              </Button>
              <!-- Archive progress overlay -->
              <Border IsVisible="{Binding IsArchiving}" Background="#CC000000"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                  <TextBlock Text="Archiving..." FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                  <ProgressBar Value="{Binding ArchiveProgress}" Minimum="0" Maximum="1" Height="4" Width="200"/>
                  <Button Content="Stop Archiving" Command="{Binding CancelArchiveCommand}"
                          HorizontalAlignment="Center" Padding="12,8"/>
                </StackPanel>
              </Border>
            </Panel>

            <!-- Player controls -->
            <StackPanel Margin="16,8" Spacing="8">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding CurrentTimeFormatted}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding SeekPosition, Mode=OneWay}" Margin="8,0"/>
                <TextBlock Grid.Column="2" Text="{Binding TotalDurationFormatted}" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Command="{Binding PreviousFrameCommand}" ToolTip.Tip="Previous frame" Width="44" Height="44" CornerRadius="22">
                  <PathIcon Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" Width="20" Height="20"/>
                </Button>
                <Button Command="{Binding PlayPauseCommand}" Width="44" Height="44" CornerRadius="22" ToolTip.Tip="Play/Pause">
                  <Panel>
                    <PathIcon IsVisible="{Binding !IsPlaying}" Data="M8,5.14V19.14L19,12.14L8,5.14Z" Width="20" Height="20"/>
                    <PathIcon IsVisible="{Binding IsPlaying}" Data="M14,19H18V5H14M6,19H10V5H6V19Z" Width="20" Height="20"/>
                  </Panel>
                </Button>
                <Button Command="{Binding NextFrameCommand}" ToolTip.Tip="Next frame" Width="44" Height="44" CornerRadius="22">
                  <PathIcon Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" Width="20" Height="20"/>
                </Button>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <Button Content="0.5x" Command="{Binding SetRateCommand}" CommandParameter="0.5" FontSize="12" Padding="8,4" CornerRadius="4"/>
                <Button Content="1x" Command="{Binding SetRateCommand}" CommandParameter="1" FontSize="12" Padding="8,4" CornerRadius="4"/>
                <Button Content="2x" Command="{Binding SetRateCommand}" CommandParameter="2" FontSize="12" Padding="8,4" CornerRadius="4"/>
              </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#33FFFFFF" Margin="16,0"/>

            <!-- Metadata -->
            <StackPanel Spacing="24" Margin="16">
              <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="SemiBold"/>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Date / Time" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DisplayDateTime}" FontSize="14"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Duration" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayDuration}" FontSize="14"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="File Size" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DisplayFileSize}" FontSize="14"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Avg Speed" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DisplayAvgSpeed}" FontSize="14"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Peak G-Force" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DisplayPeakGForce}" FontSize="14"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Distance" FontSize="12" Opacity="0.7"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DisplayDistance}" FontSize="14"/>
              </Grid>

              <!-- Trip clips -->
              <StackPanel IsVisible="{Binding IsTrip}" Spacing="8">
                <TextBlock Text="Clips in this trip" FontSize="18" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding CurrentClips}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8,6" Margin="0,2" Background="#1AFFFFFF" CornerRadius="4">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Column="1" Text="{Binding Duration}" FontSize="12" Opacity="0.6" Margin="8,0,0,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Archive buttons -->
              <Button IsVisible="{Binding !IsTrip}" HorizontalAlignment="Stretch" Content="Archive Recording"
                      Command="{Binding ArchiveRecordingCommand}" IsEnabled="{Binding !IsArchived}" Padding="16,12" CornerRadius="8"/>
              <Button IsVisible="{Binding IsTrip}" HorizontalAlignment="Stretch" Content="Archive Entire Trip"
                      Command="{Binding ArchiveRecordingCommand}" IsEnabled="{Binding !IsArchived}" Padding="16,12" CornerRadius="8"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Archive progress overlay (full-screen, shown during batch archive) -->
    <Border IsVisible="{Binding IsArchiving}"
            Background="#CC000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <TextBlock Text="{Binding ArchiveStatusText}"
                   FontSize="14" Foreground="White"
                   HorizontalAlignment="Center"/>
        <ProgressBar Value="{Binding ArchiveProgress}"
                     Minimum="0" Maximum="1"
                     Height="4" Width="200"/>
        <Button Content="Stop Archiving"
                Command="{Binding CancelArchiveCommand}"
                HorizontalAlignment="Center"
                Padding="12,8"/>
      </StackPanel>
    </Border>

  </Panel>

</ContentPage>
