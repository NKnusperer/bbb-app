<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BlackBoxBuddy.ViewModels"
             x:Class="BlackBoxBuddy.Views.LiveFeedPage"
             x:DataType="vm:LiveFeedViewModel">

  <Grid RowDefinitions="*,Auto">

    <!-- Row 0: Video area panel -->
    <Panel Grid.Row="0" Background="#111111">

      <!-- VideoView placeholder — Desktop-only control populated in code-behind.
           ContentControl x:Name="VideoViewHost" is populated via reflection in LiveFeedPage.axaml.cs
           to avoid compile-time dependency on BlackBoxBuddy.Desktop.Controls. -->
      <ContentControl x:Name="VideoViewHost"
                      IsVisible="{Binding IsStreamActive}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

      <!-- Loading placeholder -->
      <StackPanel IsVisible="{Binding IsLoading}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16">
        <ProgressBar IsIndeterminate="True" Width="160" Height="4"/>
        <TextBlock Text="Connecting to camera..."
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Connection loss placeholder -->
      <StackPanel IsVisible="{Binding IsConnectionLost}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="8">
        <PathIcon Width="48" Height="48" Opacity="0.5"
                  Foreground="White"
                  Data="M18,10.48V6c0-1.1-0.9-2-2-2H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2v-4.48l4,3.98v-11L18,10.48z M10,15L5.5,9l2-2.5L10,10l4-5l2,2.5L10,15z"
                  HorizontalAlignment="Center"/>
        <TextBlock Text="Connection lost"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Check your dashcam connection and try again."
                   FontSize="14"
                   Foreground="White"
                   Opacity="0.7"
                   HorizontalAlignment="Center"/>
        <Button Content="Retry Connection"
                Command="{Binding RetryCommand}"
                Padding="24,8"
                CornerRadius="8"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"/>
      </StackPanel>

    </Panel>

    <!-- Row 1: Camera toggle segmented control (always visible) -->
    <Border Grid.Row="1"
            Height="44"
            Margin="16,8"
            CornerRadius="22"
            Background="#1AFFFFFF"
            ClipToBounds="True">
      <Grid ColumnDefinitions="*,*">
        <Button Grid.Column="0"
                Content="Front"
                Command="{Binding ToggleCameraCommand}"
                CommandParameter="front"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="12,8"
                CornerRadius="22"
                BorderThickness="0"
                FontSize="14"
                x:Name="FrontButton"/>
        <Button Grid.Column="1"
                Content="Rear"
                Command="{Binding ToggleCameraCommand}"
                CommandParameter="rear"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="12,8"
                CornerRadius="22"
                BorderThickness="0"
                FontSize="14"
                x:Name="RearButton"/>
      </Grid>
    </Border>

  </Grid>

</ContentPage>
