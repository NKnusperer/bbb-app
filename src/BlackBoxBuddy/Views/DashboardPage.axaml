<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BlackBoxBuddy.ViewModels"
             xmlns:models="using:BlackBoxBuddy.Models"
             xmlns:conv="using:BlackBoxBuddy.Converters"
             x:Class="BlackBoxBuddy.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel">

  <ContentPage.Resources>
    <conv:EventTypeToBrushConverter x:Key="EventTypeToBrush"/>
    <conv:EventTypeToStringConverter x:Key="EventTypeToString"/>
    <conv:EventTypeToVisibilityConverter x:Key="EventTypeToVisibility"/>
    <conv:BytesToBitmapConverter x:Key="BytesToBitmap"/>
  </ContentPage.Resources>

  <Panel>

    <!-- Loading state -->
    <StackPanel IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
      <ProgressBar IsIndeterminate="True" Width="160" Height="4"/>
      <TextBlock Text="Loading dashboard..."
                 FontSize="14"
                 Foreground="White"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Empty state (no device connected AND not loaded) -->
    <StackPanel IsVisible="{Binding IsEmptyState}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="No dashcam connected"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="White"
                 TextAlignment="Center"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Connect your dashcam to see recent recordings and trips."
                 FontSize="14"
                 Foreground="White"
                 Opacity="0.7"
                 TextAlignment="Center"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Main content — scrollable sections -->
    <ScrollViewer IsVisible="{Binding IsDashboardLoaded}"
                  VerticalScrollBarVisibility="Auto"
                  Padding="16">
      <StackPanel Spacing="0">

        <!-- Section 1: Recent Recordings (per D-08, DASH-01) -->
        <StackPanel Margin="0,0,0,24">
          <!-- Section header -->
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Text="Recent Recordings"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"/>
            <Button Grid.Column="1"
                    Content="See All"
                    Command="{Binding SeeAllRecordingsCommand}"
                    FontSize="14"
                    Foreground="#2196F3"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="0"/>
          </Grid>
          <!-- Card list -->
          <ItemsControl ItemsSource="{Binding RecentRecordings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Recording">
                <Button Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).OpenRecordingCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        Padding="0"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                  <Border CornerRadius="8" Padding="8" Background="#1AFFFFFF">
                    <Grid ColumnDefinitions="88,*" ColumnSpacing="8">
                      <Panel Width="88" Height="50" ClipToBounds="True">
                        <Image Width="88" Height="50" Stretch="UniformToFill"
                               Source="{Binding ThumbnailData, Converter={StaticResource BytesToBitmap}, ConverterParameter=88x50}"/>
                        <!-- Event badge overlay -->
                        <Border IsVisible="{Binding EventType, Converter={StaticResource EventTypeToVisibility}}"
                                Background="{Binding EventType, Converter={StaticResource EventTypeToBrush}}"
                                CornerRadius="4" Padding="4,2"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0">
                          <TextBlock Text="{Binding EventType, Converter={StaticResource EventTypeToString}}"
                                     FontSize="10" Foreground="White"/>
                        </Border>
                      </Panel>
                      <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DateTime, StringFormat='{}{0:MMM dd  HH:mm}'}"
                                   FontSize="12" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                   FontSize="12" Foreground="White" Opacity="0.7"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Section 2: Recent Trips (per D-08, DASH-02) -->
        <StackPanel Margin="0,0,0,24">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Text="Recent Trips"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"/>
            <Button Grid.Column="1"
                    Content="See All"
                    Command="{Binding SeeAllTripsCommand}"
                    FontSize="14"
                    Foreground="#2196F3"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="0"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding RecentTrips}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:TripGroup">
                <Button Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).OpenTripCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        Padding="0"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                  <Border CornerRadius="8" Padding="8" Background="#1AFFFFFF">
                    <Grid ColumnDefinitions="88,*" ColumnSpacing="8">
                      <Panel Width="88" Height="50" ClipToBounds="True">
                        <!-- First clip thumbnail -->
                        <Image Width="88" Height="50" Stretch="UniformToFill"
                               Source="{Binding Clips[0].ThumbnailData, Converter={StaticResource BytesToBitmap}, ConverterParameter=88x50}"/>
                      </Panel>
                      <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="Trip" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" Opacity="0.7">
                            <TextBlock.Text>
                              <MultiBinding StringFormat="· {0} clips">
                                <Binding Path="Clips.Count"/>
                              </MultiBinding>
                            </TextBlock.Text>
                          </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding StartTime, StringFormat='{}{0:MMM dd  HH:mm}'}"
                                   FontSize="12" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{Binding TotalDuration, StringFormat='{}{0:mm\\:ss}'}"
                                   FontSize="12" Foreground="White" Opacity="0.7"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Section 3: Recent Events (per D-08, DASH-03) -->
        <StackPanel Margin="0,0,0,24">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Text="Recent Events"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"/>
            <Button Grid.Column="1"
                    Content="See All"
                    Command="{Binding SeeAllEventsCommand}"
                    FontSize="14"
                    Foreground="#2196F3"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="0"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding RecentEvents}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Recording">
                <Button Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).OpenRecordingCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        Padding="0"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                  <Border CornerRadius="8" Padding="8" Background="#1AFFFFFF">
                    <Grid ColumnDefinitions="88,*" ColumnSpacing="8">
                      <Panel Width="88" Height="50" ClipToBounds="True">
                        <Image Width="88" Height="50" Stretch="UniformToFill"
                               Source="{Binding ThumbnailData, Converter={StaticResource BytesToBitmap}, ConverterParameter=88x50}"/>
                        <Border IsVisible="{Binding EventType, Converter={StaticResource EventTypeToVisibility}}"
                                Background="{Binding EventType, Converter={StaticResource EventTypeToBrush}}"
                                CornerRadius="4" Padding="4,2"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0">
                          <TextBlock Text="{Binding EventType, Converter={StaticResource EventTypeToString}}"
                                     FontSize="10" Foreground="White"/>
                        </Border>
                      </Panel>
                      <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DateTime, StringFormat='{}{0:MMM dd  HH:mm}'}"
                                   FontSize="12" Foreground="White" Opacity="0.85"/>
                        <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss}'}"
                                   FontSize="12" Foreground="White" Opacity="0.7"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Panel>

</ContentPage>
