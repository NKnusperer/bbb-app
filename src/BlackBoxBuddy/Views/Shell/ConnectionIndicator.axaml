<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BlackBoxBuddy.ViewModels.Shell"
             xmlns:converters="using:BlackBoxBuddy.Converters"
             x:Class="BlackBoxBuddy.Views.Shell.ConnectionIndicator"
             x:DataType="vm:AppShellViewModel">
  <UserControl.Resources>
    <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToBrush"/>
  </UserControl.Resources>
  <Button Command="{Binding ConnectionIndicatorTappedCommand}"
          Background="Transparent"
          BorderThickness="0"
          Padding="0">
    <Border Padding="8,4" CornerRadius="4" Background="#1EFFFFFF">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <!-- State dot — color changes per ConnectionState via converter -->
        <Ellipse Width="10" Height="10"
                 VerticalAlignment="Center"
                 Fill="{Binding ConnectionState, Converter={StaticResource ConnectionStateToBrush}}"/>
        <!-- Status text -->
        <TextBlock Text="{Binding ConnectionStatusText}"
                   VerticalAlignment="Center"
                   FontSize="13"/>
      </StackPanel>
    </Border>
  </Button>
</UserControl>
